---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
  buildWebflowSidebar,
  getAllArticles,
  getArticleSegments,
  getAllTags,
} from '../lib/webflow';

export const prerender = true;

const articles = await getAllArticles();
const tags = await getAllTags();
const tagMap = new Map(tags.map(tag => [tag.id, tag]));
const sidebar = buildWebflowSidebar(articles, tagMap);

const moduleCards = [
  {
    slug: 'front-desk-module',
    title: 'Front Desk Module',
    description: 'Master appointment booking, calendar management, and patient check-in workflows',
    icon: 'book',
  },
  {
    slug: 'clinicians-module',
    title: "Clinician's Module",
    description: 'Learn documentation features, SOAP notes, and patient management tools',
    icon: 'doc',
  },
  {
    slug: 'billing-videos',
    title: 'Billing Videos',
    description: 'Understanding billing dashboard, claims, e-wallet, and financial processes',
    icon: 'video',
  },
  {
    slug: 'profile-management',
    title: 'Profile Management',
    description: 'Configure user settings, permissions, and account preferences',
    icon: 'help',
  },
].map((card) => {
  return {
    ...card,
    href: `/${card.slug}`,
  };
});

function pickArticleByKeywords(keywords: string[]) {
  const lowerKeywords = keywords.map((k) => k.toLowerCase());
  return articles.find((article) => {
    const name = String(article.name || '').toLowerCase();
    const slug = String(article.slug || '').toLowerCase();
    return lowerKeywords.some((kw) => name.includes(kw) || slug.includes(kw));
  });
}

const popularArticles = [
  {
    title: 'How to Book an Appointment',
    match: ['book an appointment', 'appointment-booking', 'appointment'],
  },
  {
    title: 'Understanding SOAP Notes',
    match: ['soap notes', 'soap-note', 'soap'],
  },
  {
    title: 'Billing Dashboard Overview',
    match: ['billing dashboard overview', 'billing-dashboard-overview', 'billing-dashboard'],
  },
  {
    title: 'Patient Management Guide',
    match: ['patient management guide', 'patient-management', 'patient management'],
  },
].map((entry) => {
  const article = pickArticleByKeywords(entry.match);
  return {
    title: article?.name || entry.title,
    href: article?.slug ? `/${article.slug}` : '/',
  };
});
---

<StarlightPage
  frontmatter={{
    title: '',
    description: 'Your one-stop hub for guides, videos, and step-by-step workflows.',
  }}
  sidebar={sidebar}
>
  <section class="spry-home spry-home-page">
    <header class="spry-home-header-hero">
      <div class="spry-home-header-content">
        <p class="spry-home-version-pill">SPRY Help Center</p>
        <h1>
          Your SPRY<br />
          Playbook,<br />
          <span class="spry-home-gradient-text">by Role.</span>
        </h1>
        <p class="spry-home-header-copy">
          Everything your clinic needs from day one setup to advanced workflows, organized for the way your team actually works.
        </p>
        <div class="spry-home-role-chips" aria-label="Browse by role">
          <a class="spry-home-role-chip" href="/clinicians-module">
            <span class="spry-home-role-chip-icon spry-home-hero-icon" aria-hidden="true">
              <img src="/assets/Clinicians module.svg" alt="" />
            </span>
            <span>Clinician</span>
          </a>
          <a class="spry-home-role-chip" href="/front-desk-module">
            <span class="spry-home-role-chip-icon spry-home-hero-icon" aria-hidden="true">
              <img src="/assets/Front desk module.svg" alt="" />
            </span>
            <span>Front Desk</span>
          </a>
          <a class="spry-home-role-chip" href="/billing-videos">
            <span class="spry-home-role-chip-icon spry-home-hero-icon" aria-hidden="true">
              <img src="/assets/Billing Videos.svg" alt="" />
            </span>
            <span>Billing</span>
          </a>
          <a class="spry-home-role-chip" href="/profile-management">
            <span class="spry-home-role-chip-icon spry-home-hero-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5z" />
                <path d="M2 20c0-3.866 3.582-7 10-7s10 3.134 10 7v1H2v-1z" />
              </svg>
            </span>
            <span>Admin</span>
          </a>
        </div>
        <div class="spry-home-header-actions">
          <a class="spry-home-btn spry-home-btn-primary" href="/front-desk-module">Get Started</a>
        </div>
      </div>

      <div class="spry-home-header-visual" aria-hidden="true">
        <div class="spry-home-header-visual-inner">
          <img src="/assets/Frame 1686554307 (1).png" alt="Hero visual" loading="eager" decoding="async" />
        </div>
      </div>
    </header>

    <section class="spry-module-section" aria-label="Explore by Module">
      <div class="spry-module-header">
        <h2>Explore by Module</h2>
        <p>Browse comprehensive guides organized by your workflow</p>
      </div>

      <div class="spry-module-grid">
        {moduleCards.map((card) => (
          <a class="spry-module-card" href={card.href}>
            <div class="spry-module-card-top">
              <div class="spry-module-icon" aria-hidden="true">
                {card.icon === 'book' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path d="M12 5.75c-1.56-1-3.48-1.6-5.39-1.6A1.73 1.73 0 0 0 4.9 5.9v9.43A1.6 1.6 0 0 0 6.5 16.9c1.87 0 3.82.58 5.23 1.55a.52.52 0 0 0 .54 0c1.41-.97 3.36-1.55 5.23-1.55a1.6 1.6 0 0 0 1.6-1.57V5.9a1.73 1.73 0 0 0-1.71-1.75c-1.91 0-3.83.6-5.39 1.6Zm-.7 10.6a12 12 0 0 0-4.95-1.25V6.1c1.68.04 3.45.54 4.95 1.38Zm1.4 0V7.48c1.5-.84 3.27-1.34 4.95-1.38v8.99a12 12 0 0 0-4.95 1.26Z" />
                  </svg>
                )}
                {card.icon === 'doc' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path d="M7 3.75h6.6a2 2 0 0 1 1.42.59l1.64 1.64a2 2 0 0 1 .59 1.42v10.85a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-12.5a2 2 0 0 1 2-2Zm0 1.5a.5.5 0 0 0-.5.5v12.5a.5.5 0 0 0 .5.5h8.25a.5.5 0 0 0 .5-.5V7.4l-2.2-2.15Zm2 5h5v1.4H9Zm0 3h5v1.4H9Z" />
                  </svg>
                )}
                {card.icon === 'video' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path d="M7 6h7.6a2 2 0 0 1 2 2v2.2l2.4-1.55a1 1 0 0 1 1.55.84v5.02a1 1 0 0 1-1.55.84L16.6 13.8V16a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm0 1.5a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h7.6a.5.5 0 0 0 .5-.5V8a.5.5 0 0 0-.5-.5Z" />
                  </svg>
                )}
                {card.icon === 'help' && (
                  <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                    <path d="M12 3.75a8.25 8.25 0 1 0 8.25 8.25A8.26 8.26 0 0 0 12 3.75Zm0 15a6.75 6.75 0 1 1 6.75-6.75A6.76 6.76 0 0 1 12 18.75Zm-.15-3.15h1.5v1.5h-1.5Zm.95-8.1a2.6 2.6 0 0 0-2.8 1.45l1.3.66a1.14 1.14 0 0 1 1.22-.63c.65 0 1.13.34 1.13.86 0 .5-.3.8-1.06 1.23-.98.56-1.68 1.1-1.68 2.37v.3h1.5v-.22c0-.72.32-1.04 1.13-1.5.91-.52 1.61-1.1 1.61-2.2 0-1.34-1.16-2.32-2.35-2.32Z" />
                  </svg>
                )}
              </div>
            </div>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <div class="spry-module-card-footer">
              <span class="spry-module-footer-link">
                <span>Explore</span>
                <span class="spry-module-arrow" aria-hidden="true">›</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="spry-popular-section" aria-label="Popular Articles">
      <div class="spry-popular-header">
        <h2>Popular Articles</h2>
        <p>Quick access to frequently viewed guides</p>
      </div>

      <div class="spry-popular-grid">
        {popularArticles.map((article) => (
          <a class="spry-popular-card" href={article.href}>
            <span class="spry-popular-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                <path d="M7 3.75h6.6a2 2 0 0 1 1.42.59l1.64 1.64a2 2 0 0 1 .59 1.42v10.85a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-12.5a2 2 0 0 1 2-2Zm0 1.5a.5.5 0 0 0-.5.5v12.5a.5.5 0 0 0 .5.5h8.25a.5.5 0 0 0 .5-.5V7.4l-2.2-2.15Zm2 5h5v1.4H9Zm0 3h5v1.4H9Z" />
              </svg>
            </span>
            <span class="spry-popular-title">{article.title}</span>
            <span class="spry-popular-arrow" aria-hidden="true">›</span>
          </a>
        ))}
      </div>
    </section>

    <section class="spry-home-help-section" aria-label="Need help">
      <h2>Still need help?</h2>
      <p>Can't find what you're looking for? Our support team is here to assist you.</p>
      <div class="spry-home-help-actions">
        <a class="spry-home-help-btn spry-home-help-btn-primary" href="mailto:support@spryhealth.care">
          Contact Support
        </a>
        <a class="spry-home-help-btn spry-home-help-btn-secondary" href="/new-features">
          Request Feature
        </a>
      </div>
    </section>
  </section>
</StarlightPage>
